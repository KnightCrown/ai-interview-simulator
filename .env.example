# Use a single line per variable. If OPENAI_API_KEY appears twice, Next.js / dotenv
# will use the last one in that file — avoid duplicates with conflicting values.
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Required for /interview/live (LiveAvatar). HeyGen Streaming Avatar API is sunset;
# use LiveAvatar keys from app.liveavatar.com — see https://docs.liveavatar.com/docs/faq/migration-guide
# LIVEAVATAR_API_KEY falls back to HEYGEN_API_KEY for older .env files.
LIVEAVATAR_API_KEY=your_liveavatar_api_key_here
# Avatar UUID from LiveAvatar (not the legacy HeyGen numeric id).
LIVEAVATAR_AVATAR_ID=your_avatar_uuid_here
# HEYGEN_API_KEY=legacy_fallback_same_as_liveavatar_key
